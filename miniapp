<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>BaseKit MiniApp</title>

<script src="https://cdn.jsdelivr.net/npm/@farcaster/frame-sdk@latest/dist/index.min.js"></script>

<style>
body{
  margin:0;
  background:#000;
  display:flex;
  align-items:center;
  justify-content:center;
  height:100vh;
  font-family:sans-serif;
  color:#0052FF;
  text-align:center;
}
.box{
  border:1px solid #0052FF;
  padding:25px;
  border-radius:14px;
  background:#050505;
  width:90%;
  max-width:400px;
}
button{
  margin-top:20px;
  padding:14px;
  width:100%;
  border:none;
  border-radius:10px;
  background:#0052FF;
  color:#fff;
  font-weight:bold;
  cursor:pointer;
}
</style>
</head>
<body>

<div class="box" id="app" style="display:none;">
  <h2>BaseKit Supporter</h2>
  <p style="color:#00ff00;font-family:monospace;">
    Connected to Farcaster
  </p>
  <button onclick="openSite()">Launch Website</button>
</div>

<script>
function boot() {

  let attempts = 0;

  const interval = setInterval(() => {

    if (window.farcaster?.actions) {

      window.farcaster.actions.ready();   // 🔥 handshake

      clearInterval(interval);

      document.getElementById("app").style.display = "block";
    }

    attempts++;
    if (attempts > 100) clearInterval(interval);

  }, 50);
}

function openSite(){
  window.farcaster.actions.openUrl("https://basekit.online");
}

boot();
</script>

</body>
</html>
